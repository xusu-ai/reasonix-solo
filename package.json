{
  "name": "reasonix",
  "version": "0.47.2",
  "description": "Reasonix-Solo: Single-Page WebUI AI coding assistant — pure Node.js, no GPU, any browser.",
  "type": "module",
  "bin": {
    "reasonix": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "data/deepseek-tokenizer.json.gz",
    "dashboard/index.html",
    "dashboard/app.css",
    "dashboard/dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-dashboard-vendor-css.mjs && node scripts/copy-tree-sitter-grammars.mjs",
    "dev": "tsx src/cli/index.ts",
    "chat": "tsx src/cli/index.ts chat",
    "typecheck": "tsc --noEmit && tsc --noEmit -p dashboard"
  },
  "keywords": [
    "agent",
    "llm",
    "deepseek",
    "r1",
    "tool-use",
    "prompt-cache",
    "cli",
    "tui"
  ],
  "author": "esengine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xusu-ai/reasonix-solo.git"
  },
  "bugs": {
    "url": "https://github.com/xusu-ai/reasonix-solo/issues"
  },
  "homepage": "https://github.com/xusu-ai/reasonix-solo#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "eventsource-parser": "^3.0.0",
    "ignore": "^7.0.5",
    "ink": "^7.0.2",
    "ink-text-input": "^6.0.0",
    "node-html-parser": "^7.1.0",
    "picomatch": "^4.0.4",
    "react": "^19.2.6",
    "string-width": "^7.2.0",
    "undici": "^8.2.0",
    "web-tree-sitter": "^0.26.9",
    "ws": "^8.20.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.21.5",
    "highlight.js": "^11.10.0",
    "htm": "^3.1.1",
    "marked": "^15.0.12",
    "preact": "^10.22.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "uplot": "^1.6.31"
  }
}
